modules = ["nodejs-24", "postgresql-16"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
BASE_PATH = "/"
FLW_SECRET_KEY = "b449522c-3612-498d-8f07-d8390d466f54"
FLW_SECRET_HASH = "ziVgmkUZHFbYy2CZCJv1YlMnC0Fiw99y"
GW_JWT_SECRET = "5ad7eb278793e81496ab3d44f4165986c2dfb7073a02393eeda3dfaa7e4a2a46"
SMM_API_KEY = "f50b7f2b620987cc1a9a906a3dc38e40"
TELEGRAM_CONTROL_CHAT_ID = "7624983543"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "WhatsApp Bot"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev & PORT=5000 pnpm --filter @workspace/telegram-bot run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "WhatsApp Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8000 pnpm --filter @workspace/whatsapp-bot run start"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

