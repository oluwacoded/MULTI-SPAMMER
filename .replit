modules = ["nodejs-24"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
BASE_PATH = "/"

[workflows]

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 4200

[[ports]]
localPort = 8083
externalPort = 5173

[[ports]]
localPort = 18199
externalPort = 3003

[[ports]]
localPort = 20689
externalPort = 3002

[[ports]]
localPort = 21002
externalPort = 3000

[[ports]]
localPort = 23639
externalPort = 3001

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "NODE_ENV=production PORT=8080 node --enable-source-maps ./artifacts/api-server/dist/index.mjs"]
build = ["bash", "-c", "pnpm install --frozen-lockfile && PORT=5000 BASE_PATH=/ pnpm --filter @workspace/telegram-bot run build && pnpm --filter @workspace/api-server run build"]
