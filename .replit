[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "NODE_ENV=production PORT=8080 node --enable-source-maps ./artifacts/api-server/dist/index.mjs"]
build = ["bash", "-c", "pnpm install --frozen-lockfile && PORT=5000 BASE_PATH=/ pnpm --filter @workspace/telegram-bot run build && pnpm --filter @workspace/api-server run build"]
